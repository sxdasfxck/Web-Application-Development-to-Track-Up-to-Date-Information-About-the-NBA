@model NBA_Website.Models.RosterViewModel

@{
    ViewData["Title"] = $"Состав {Model.TeamName}";
}

<style>
    .roster-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 30px 20px;
    }

    .team-header {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        border-radius: 20px;
        padding: 40px;
        margin-bottom: 30px;
        position: relative;
        overflow: hidden;
        border: 1px solid #e0e0e0;
    }

        .team-header::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 8px;
            background: linear-gradient(90deg, # @Model.TeamColor 0%, # @Model.TeamColor 100%);
        }

    .team-header-content {
        display: flex;
        align-items: center;
        gap: 40px;
        flex-wrap: wrap;
    }

    .team-logo {
        width: 150px;
        height: 150px;
        object-fit: contain;
        filter: drop-shadow(0 10px 20px rgba(0,0,0,0.2));
        background: white;
        border-radius: 50%;
        padding: 20px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }

    .team-title {
        flex: 1;
    }

    .team-name {
        font-size: 2.5em;
        font-weight: 800;
        color: #1a1a1a;
        margin-bottom: 10px;
        letter-spacing: -0.02em;
    }

    .team-season {
        font-size: 1.2em;
        color: #666;
        margin-bottom: 15px;
        display: flex;
        align-items: center;
        gap: 15px;
        flex-wrap: wrap;
    }

    .team-badges {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .badge {
        background: #ff6b35;
        color: white;
        padding: 8px 20px;
        border-radius: 25px;
        font-size: 1em;
        font-weight: 600;
        text-transform: uppercase;
    }

    .badge-outline {
        background: transparent;
        color: #666;
        border: 1px solid #ddd;
    }

    .coach-info {
        display: flex;
        align-items: center;
        gap: 8px;
        background: #f0f0f0;
        color: #333;
        padding: 6px 15px;
        border-radius: 25px;
        font-size: 0.95em;
        font-weight: 500;
    }

        .coach-info i {
            color: #ff6b35;
            font-size: 1.1em;
        }

    .players-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 20px;
        margin-top: 30px;
    }

    .player-card {
        background: white;
        border-radius: 15px;
        overflow: hidden;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        border: 1px solid #e0e0e0;
        transition: transform 0.3s ease;
        display: flex;
        flex-direction: column;
        text-decoration: none;
        color: inherit;
    }

        .player-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.1);
        }

    .player-header {
        height: 8px;
        width: 100%;
        background: linear-gradient(90deg, # @Model.TeamColor 0%, # @Model.TeamColor 100%);
    }

    .player-image-container {
        padding: 20px;
        display: flex;
        justify-content: center;
        align-items: center;
        background: #f5f5f5;
        height: 180px;
        position: relative;
    }

    .player-image {
        max-width: 120px;
        max-height: 120px;
        object-fit: contain;
        border-radius: 50%;
        background: white;
        padding: 5px;
        box-shadow: 0 3px 10px rgba(0,0,0,0.1);
        transition: transform 0.3s ease;
        position: relative;
        z-index: 2;
    }

    .player-card:hover .player-image {
        transform: scale(1.05);
    }

    .flag-background {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        opacity: 0.15;
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        z-index: 1;
        transition: opacity 0.3s ease;
    }

    .player-card:hover .flag-background {
        opacity: 0.25;
    }

    .flag-background-un {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, #009edb 0%, #4a9eff 100%);
        opacity: 0.15;
        z-index: 1;
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 3em;
        color: white;
    }

        .flag-background-un::before {
            content: "🇺🇳";
            font-size: 3em;
            opacity: 0.3;
        }

    .player-country {
        position: absolute;
        top: 10px;
        right: 10px;
        background: rgba(255,255,255,0.9);
        padding: 4px 10px;
        border-radius: 15px;
        font-size: 0.8em;
        font-weight: 600;
        color: #666;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        z-index: 3;
        display: flex;
        align-items: center;
        gap: 4px;
    }

        .player-country i {
            color: #ff6b35;
            font-size: 0.9em;
        }

    .player-info {
        padding: 20px;
        text-align: center;
        position: relative;
        z-index: 2;
        background: white;
    }

    .player-name {
        font-size: 1.4em;
        font-weight: 700;
        color: #333;
        margin-bottom: 5px;
        transition: color 0.2s ease;
    }

    .player-card:hover .player-name {
        color: #ff6b35;
    }

    .player-position {
        color: #ff6b35;
        font-weight: 600;
        margin-bottom: 15px;
        text-transform: uppercase;
        font-size: 0.95em;
        letter-spacing: 0.5px;
    }

    .player-salary {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        background: linear-gradient(135deg, #1d428a 0%, #2d5ab9 100%);
        color: white;
        padding: 8px 15px;
        border-radius: 25px;
        font-size: 0.95em;
        font-weight: 600;
        margin: 15px 0 10px;
        width: fit-content;
        margin-left: auto;
        margin-right: auto;
        box-shadow: 0 4px 10px rgba(29,66,138,0.2);
    }

        .player-salary i {
            font-size: 1.1em;
        }

    .player-details {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 15px;
        margin-top: 15px;
        padding-top: 15px;
        border-top: 1px solid #eee;
    }

    .detail-item {
        text-align: center;
        background: #f8f9fa;
        padding: 8px 5px;
        border-radius: 8px;
    }

    .detail-label {
        font-size: 0.8em;
        color: #999;
        text-transform: uppercase;
        margin-bottom: 4px;
    }

    .detail-value {
        font-size: 1.1em;
        font-weight: 600;
        color: #333;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 5px;
    }

        .detail-value i {
            color: #ff6b35;
            font-size: 0.9em;
        }

    .loading-spinner {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 400px;
    }

    .spinner {
        border: 5px solid #f3f3f3;
        border-top: 5px solid #ff6b35;
        border-radius: 50%;
        width: 50px;
        height: 50px;
        animation: spin 1s linear infinite;
    }

    @@keyframes spin {
        0% {
            transform: rotate(0deg);
        }

        100% {
            transform: rotate(360deg);
        }
    }

    .no-players {
        text-align: center;
        padding: 60px;
        background: #f9f9f9;
        border-radius: 15px;
        color: #666;
    }

    .action-buttons {
        display: flex;
        gap: 15px;
        justify-content: center;
        margin: 30px 0;
    }

    .btn {
        display: inline-block;
        padding: 12px 25px;
        border-radius: 30px;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .btn-primary {
        background: #ff6b35;
        color: white;
    }

        .btn-primary:hover {
            background: #ff5420;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(255,107,53,0.3);
        }

    .btn-secondary {
        background: #f0f0f0;
        color: #666;
    }

        .btn-secondary:hover {
            background: #e0e0e0;
            transform: translateY(-2px);
        }

    .back-button {
        display: inline-block;
        background: #ff6b35;
        color: white;
        padding: 12px 30px;
        border-radius: 30px;
        text-decoration: none;
        font-weight: 600;
        margin-top: 30px;
        transition: all 0.3s ease;
        border: 2px solid transparent;
    }

        .back-button:hover {
            background: white;
            color: #ff6b35;
            border-color: #ff6b35;
            transform: translateX(-5px);
        }

        .back-button i {
            margin-right: 8px;
        }

    @@media (max-width: 768px) {
        .team-header-content {
            flex-direction: column;
            text-align: center;
        }

        .team-name {
            font-size: 2em;
        }

        .players-grid {
            grid-template-columns: 1fr;
        }

        .team-season {
            justify-content: center;
        }
    }
</style>

<div class="roster-container">
    <div class="team-header">
        <div class="team-header-content">
            <img src="@Model.TeamLogo" class="team-logo" alt="@Model.TeamName">
            <div class="team-title">
                <h1 class="team-name">@(string.IsNullOrEmpty(Model.TeamName) ? Model.TeamAbbrev : Model.TeamName)</h1>
                <div class="team-badges">
                    <span class="badge" style="background: #@Model.TeamColor;">@Model.TeamAbbrev</span>
                    <span class="badge badge-outline"><i class="fas fa-users" style="margin-right: 5px;"></i>@Model.TotalPlayers игроков</span>
                    @if (!string.IsNullOrEmpty(Model.HeadCoach))
                    {
                        <span class="coach-info">
                            <i class="fas fa-user-tie"></i> Тренер: @Model.HeadCoach
                        </span>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (Model.TotalPlayers > 0)
    {
        <div class="players-grid">
            @for (int i = 0; i < Model.TotalPlayers; i++)
            {
                string playerId = "";
                if (i < Model.PlayerImages.Count)
                {
                    var match = System.Text.RegularExpressions.Regex.Match(Model.PlayerImages[i], @"full/(\d+)");
                    if (match.Success)
                    {
                        playerId = match.Groups[1].Value;
                    }
                }
                
                <a href="@(string.IsNullOrEmpty(playerId) ? "#" : Url.Action("PlayersPage", "PlayersPage", new { playerId = playerId }))" class="player-card">
                    <div class="player-header"></div>

                    <div class="player-image-container">
                        @if (i < Model.PlayerCountryCodes.Count && !string.IsNullOrEmpty(Model.PlayerCountryCodes[i]))
                        {
                            <div class="flag-background" style="background-image: url('https://flagcdn.com/w320/@(Model.PlayerCountryCodes[i]).png');"></div>
                        }
                        else
                        {
                            <div class="flag-background-un"></div>
                        }

                        <img src="@(i<Model.PlayerImages.Count? Model.PlayerImages[i] : "https://a.espncdn.com/combiner/i?img=/i/headshots/nba/players/full/0.png&w=200&h=200")"
                             class="player-image"
                             alt="@(i<Model.PlayerNames.Count? Model.PlayerNames[i] : "Игрок")"
                             onerror="this.onerror=null; this.src='https://a.espncdn.com/combiner/i?img=/i/headshots/nba/players/full/0.png&w=200&h=200';">

                        @if (i < Model.PlayerCountries.Count && !string.IsNullOrEmpty(Model.PlayerCountries[i]))
                        {
                            <span class="player-country">
                                <i class="fas fa-map-marker-alt"></i> @Model.PlayerCountries[i]
                            </span>
                        }
                        else
                        {
                            <span class="player-country">
                                <i class="fas fa-globe"></i> ООН
                            </span>
                        }
                    </div>

                    <div class="player-info">
                        <div class="player-name">@(i<Model.PlayerNames.Count? Model.PlayerNames[i] : "Неизвестно")</div>

                        <div class="player-position">
                            #@(i<Model.PlayerNumbers.Count? Model.PlayerNumbers[i] : "-") ·
                            @(i<Model.PlayerPositions.Count? Model.PlayerPositions[i] : "-")
                        </div>

                        @if (i < Model.PlayerSalaries.Count && !string.IsNullOrEmpty(Model.PlayerSalaries[i]))
                        {
                            <div class="player-salary">
                                <i class="fas fa-coins"></i> Зарплата: @Model.PlayerSalaries[i]
                            </div>
                        }

                        <div class="player-details">
                            <div class="detail-item">
                                <div class="detail-label">Рост</div>
                                <div class="detail-value">@(i<Model.PlayerHeights.Count? Model.PlayerHeights[i] : "-")</div>
                            </div>
                            <div class="detail-item">
                                <div class="detail-label">Вес</div>
                                <div class="detail-value">@(i<Model.PlayerWeights.Count? Model.PlayerWeights[i] : "-")</div>
                            </div>
                            <div class="detail-item">
                                <div class="detail-label">Возраст</div>
                                <div class="detail-value">@(i<Model.PlayerAges.Count? Model.PlayerAges[i] : "-")</div>
                            </div>
                            <div class="detail-item">
                                <div class="detail-label">Сезон</div>
                                <div class="detail-value">@(i<Model.PlayerExperiences.Count? Model.PlayerExperiences[i] : "-")</div>
                            </div>
                        </div>
                    </div>
                </a>
            }
        </div>
    }
    else
    {
        <div class="no-players">
            <i class="fas fa-users" style="font-size: 3em; color: #ccc; margin-bottom: 20px;"></i>
            <p>Информация о составе временно недоступна</p>
        </div>
    }

    <div style="text-align: center; margin-top: 30px;">
        <a href="javascript:history.back()" class="back-button">
            <i class="fas fa-arrow-left"></i> Назад
        </a>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const cards = document.querySelectorAll('.player-card');
        cards.forEach((card, index) => {
            card.style.opacity = '0';
            card.style.transform = 'translateY(20px)';
            setTimeout(() => {
                card.style.transition = 'all 0.5s ease';
                card.style.opacity = '1';
                card.style.transform = 'translateY(0)';
            }, index * 50);
        });
    });
</script>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        console.log('Roster скрипт запущен');
        
        const images = document.querySelectorAll('.player-image');
        console.log('Найдено изображений в Roster:', images.length);
        
        images.forEach((img, index) => {
            console.log(`Изображение ${index}:`, img.src);
            
            if (img.complete) {
                console.log(`Изображение ${index} уже загружено, проверяем...`);
                checkImage(img, index);
            } else {
                img.onload = function() {
                    console.log(`Изображение ${index} загрузилось, проверяем...`);
                    checkImage(this, index);
                };
            }
            
            img.onerror = function() {
                console.log(`Изображение ${index} не загрузилось (ошибка)`);
                replaceWithBlack(this);
            };
        });
        
        function checkImage(img, index) {
            try {
                const canvas = document.createElement('canvas');
                canvas.width = img.width || 120;
                canvas.height = img.height || 120;
                const ctx = canvas.getContext('2d', { willReadFrequently: true });
                
                try {
                    ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
                    
                    const points = [
                        [Math.floor(canvas.width/2), Math.floor(canvas.height/2)], 
                        [10, 10], 
                        [canvas.width-10, 10], 
                        [10, canvas.height-10], 
                        [canvas.width-10, canvas.height-10] 
                    ];
                    
                    let transparentPixels = 0;
                    
                    for (let [x, y] of points) {
                        const pixel = ctx.getImageData(x, y, 1, 1).data;
                        
                        if (pixel[3] === 0) {
                            transparentPixels++;
                        }
                    }
                    
                    if (transparentPixels === points.length) {
                        console.log(`Изображение ${index} пустое (все пиксели прозрачные)`);
                        replaceWithBlack(img);
                    } else {
                        console.log(`Изображение ${index} нормальное (${transparentPixels}/${points.length} прозрачных пикселей)`);
                    }
                    
                } catch (e) {
                    console.log(`Ошибка при анализе изображения ${index}:`, e);
                }
                
            } catch (e) {
                console.log(`Ошибка в checkImage ${index}:`, e);
            }
        }
        
        function replaceWithBlack(img) {
            img.style.backgroundColor = '#000000';
            img.src = '';           
            img.alt = '';            
            img.removeAttribute('alt'); 
            img.innerHTML = '';       
            
            const parent = img.parentNode;
            if (parent && !parent.querySelector('.black-placeholder')) {
                const placeholder = document.createElement('div');
                placeholder.className = 'black-placeholder';
                placeholder.style.width = img.width + 'px';
                placeholder.style.height = img.height + 'px';
                placeholder.style.backgroundColor = '#000000';
                placeholder.style.borderRadius = window.getComputedStyle(img).borderRadius;
                placeholder.style.margin = window.getComputedStyle(img).margin;
                placeholder.style.maxWidth = img.style.maxWidth;
                placeholder.style.maxHeight = img.style.maxHeight;
                
                parent.replaceChild(placeholder, img);
            }
        }
    });
</script>