<script>
    document.addEventListener('DOMContentLoaded', function() {
        console.log('Скрипт запущен');
        
        const images = document.querySelectorAll('.profile-image, .player-card-image, .player-image');
        console.log('Найдено изображений:', images.length);
        
        images.forEach((img, index) => {
            console.log(`Изображение ${index}:`, img.src);
            
            if (img.complete) {
                console.log(`Изображение ${index} уже загружено, проверяем...`);
                checkImage(img, index);
            } else {
                img.onload = function() {
                    console.log(`Изображение ${index} загрузилось, проверяем...`);
                    checkImage(this, index);
                };
            }
            
            img.onerror = function() {
                console.log(`Изображение ${index} не загрузилось (ошибка)`);
                this.style.backgroundColor = '#000000';
                this.src = '';
            };
        });
        
    function checkImage(img, index) {
        try {
            const canvas = document.createElement('canvas');
            canvas.width = img.width || 200;
            canvas.height = img.height || 200;
            const ctx = canvas.getContext('2d', { willReadFrequently: true });
        
            try {
                ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
            
                const points = [
                    [Math.floor(canvas.width/2), Math.floor(canvas.height/2)],
                    [10, 10],
                    [canvas.width-10, 10],
                    [10, canvas.height-10],
                    [canvas.width-10, canvas.height-10]
                ];
            
                let transparentPixels = 0;
            
                for (let [x, y] of points) {
                    const pixel = ctx.getImageData(x, y, 1, 1).data;
                    if (pixel[3] === 0) {
                        transparentPixels++;
                    }
                }
            
                if (transparentPixels === points.length) {
                    console.log(`Изображение ${index} пустое, убираем полностью`);
                                 
                    img.style.backgroundColor = '#000000';
                    img.src = '';           
                    img.alt = '';            
                    img.removeAttribute('alt'); 
                    img.innerHTML = '';       
                
                    const parent = img.parentNode;
                    if (parent && !parent.querySelector('.black-placeholder')) {
                        const placeholder = document.createElement('div');
                        placeholder.className = 'black-placeholder';
                        placeholder.style.width = img.width + 'px';
                        placeholder.style.height = img.height + 'px';
                        placeholder.style.backgroundColor = '#000000';
                        placeholder.style.borderRadius = window.getComputedStyle(img).borderRadius;
                        placeholder.style.margin = window.getComputedStyle(img).margin;
                    

                        parent.replaceChild(placeholder, img);
                    }
                }
            
            } catch (e) {
                console.log(`Ошибка при анализе изображения ${index}:`, e);
            }
        
        } catch (e) {
            console.log(`Ошибка в checkImage ${index}:`, e);
        }
    }
    });
</script>

@functions {
    public string GetTeamFullName(string abbrev)
    {
        var teamNames = new Dictionary<string, string>
        {
            {"ATL", "Atlanta Hawks"}, {"BOS", "Boston Celtics"}, {"BKN", "Brooklyn Nets"},
            {"CHA", "Charlotte Hornets"}, {"CHI", "Chicago Bulls"}, {"CLE", "Cleveland Cavaliers"},
            {"DAL", "Dallas Mavericks"}, {"DEN", "Denver Nuggets"}, {"DET", "Detroit Pistons"},
            {"GS", "Golden State Warriors"}, {"HOU", "Houston Rockets"}, {"IND", "Indiana Pacers"},
            {"LAC", "LA Clippers"}, {"LAL", "Los Angeles Lakers"}, {"MEM", "Memphis Grizzlies"},
            {"MIA", "Miami Heat"}, {"MIL", "Milwaukee Bucks"}, {"MIN", "Minnesota Timberwolves"},
            {"NO", "New Orleans Pelicans"}, {"NY", "New York Knicks"}, {"OKC", "Oklahoma City Thunder"},
            {"ORL", "Orlando Magic"}, {"PHI", "Philadelphia 76ers"}, {"PHX", "Phoenix Suns"},
            {"POR", "Portland Trail Blazers"}, {"SAC", "Sacramento Kings"}, {"SA", "San Antonio Spurs"},
            {"TOR", "Toronto Raptors"}, {"UTAH", "Utah Jazz"}, {"WSH", "Washington Wizards"}
        };
        
        return teamNames.ContainsKey(abbrev) ? teamNames[abbrev] : abbrev;
    }
}