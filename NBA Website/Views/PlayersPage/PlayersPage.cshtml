@using System.Globalization
@model NBA_Website.Models.PlayersPageViewModel

@{
    ViewData["Title"] = Model.Items != null ? "Все игроки NBA" : Model.DisplayName ?? "Профиль игрока";

    Dictionary<string, string> teamAbbrevMap = new Dictionary<string, string>
    {
        {"1", "ATL"}, {"2", "BOS"}, {"3", "NO"}, {"4", "CHI"}, {"5", "CLE"},
        {"6", "DAL"}, {"7", "DEN"}, {"8", "DET"}, {"9", "GS"}, {"10", "HOU"},
        {"11", "IND"}, {"12", "LAC"}, {"13", "LAL"}, {"14", "MIA"}, {"15", "MIL"},
        {"16", "MIN"}, {"17", "BKN"}, {"18", "NY"}, {"19", "ORL"}, {"20", "PHI"},
        {"21", "PHX"}, {"22", "POR"}, {"23", "SAC"}, {"24", "SA"}, {"25", "OKC"},
        {"26", "UTAH"}, {"27", "WSH"}, {"28", "TOR"}, {"29", "MEM"}, {"30", "CHA"}
    };

    string GetTeamAbbrev(string id)
    {
        return teamAbbrevMap.ContainsKey(id) ? teamAbbrevMap[id] : id;
    }

    string GetTeamLogoUrl(string abbrev)
    {
        if (string.IsNullOrEmpty(abbrev)) return "https://a.espncdn.com/i/teamlogos/nba/500/default.png";
        
        var lowerAbbrev = abbrev.ToLower();
        
        var logoMap = new Dictionary<string, string>
        {
            {"ATL", "atl"}, {"BOS", "bos"}, {"BKN", "bkn"}, {"CHA", "cha"}, {"CHI", "chi"},
            {"CLE", "cle"}, {"DAL", "dal"}, {"DEN", "den"}, {"DET", "det"}, {"GS", "gs"},
            {"HOU", "hou"}, {"IND", "ind"}, {"LAC", "lac"}, {"LAL", "lal"}, {"MEM", "mem"},
            {"MIA", "mia"}, {"MIL", "mil"}, {"MIN", "min"}, {"NO", "no"}, {"NY", "ny"},
            {"OKC", "okc"}, {"ORL", "orl"}, {"PHI", "phi"}, {"PHX", "phx"}, {"POR", "por"},
            {"SAC", "sac"}, {"SA", "sa"}, {"TOR", "tor"}, {"UTAH", "utah"}, {"WSH", "wsh"}
        };
        
        string logoCode = logoMap.ContainsKey(abbrev) ? logoMap[abbrev] : lowerAbbrev;
        return $"https://a.espncdn.com/i/teamlogos/nba/500/{logoCode}.png";
    }

    string FormatDate(string dateString)
    {
        if (string.IsNullOrEmpty(dateString)) return "";
        var date = DateTime.Parse(dateString);
        var culture = new CultureInfo("ru-RU");
        return date.ToString("d MMMM", culture);
    }
    
    (string venue, string city) GetVenueAndCity(string teamAbbrev)
    {
        var venues = new Dictionary<string, (string venue, string city)>
        {
            {"ATL", ("State Farm Arena", "Atlanta, GA")},
            {"BOS", ("TD Garden", "Boston, MA")},
            {"BKN", ("Barclays Center", "Brooklyn, NY")},
            {"CHA", ("Spectrum Center", "Charlotte, NC")},
            {"CHI", ("United Center", "Chicago, IL")},
            {"CLE", ("Rocket Mortgage FieldHouse", "Cleveland, OH")},
            {"DAL", ("American Airlines Center", "Dallas, TX")},
            {"DEN", ("Ball Arena", "Denver, CO")},
            {"DET", ("Little Caesars Arena", "Detroit, MI")},
            {"GS", ("Chase Center", "San Francisco, CA")},
            {"HOU", ("Toyota Center", "Houston, TX")},
            {"IND", ("Gainbridge Fieldhouse", "Indianapolis, IN")},
            {"LAC", ("Crypto.com Arena", "Los Angeles, CA")},
            {"LAL", ("Crypto.com Arena", "Los Angeles, CA")},
            {"MEM", ("FedExForum", "Memphis, TN")},
            {"MIA", ("Kaseya Center", "Miami, FL")},
            {"MIL", ("Fiserv Forum", "Milwaukee, WI")},
            {"MIN", ("Target Center", "Minneapolis, MN")},
            {"NO", ("Smoothie King Center", "New Orleans, LA")},
            {"NY", ("Madison Square Garden", "New York, NY")},
            {"OKC", ("Paycom Center", "Oklahoma City, OK")},
            {"ORL", ("Kia Center", "Orlando, FL")},
            {"PHI", ("Wells Fargo Center", "Philadelphia, PA")},
            {"PHX", ("Footprint Center", "Phoenix, AZ")},
            {"POR", ("Moda Center", "Portland, OR")},
            {"SAC", ("Golden 1 Center", "Sacramento, CA")},
            {"SA", ("Frost Bank Center", "San Antonio, TX")},
            {"TOR", ("Scotiabank Arena", "Toronto, ON")},
            {"UTAH", ("Delta Center", "Salt Lake City, UT")},
            {"WSH", ("Capital One Arena", "Washington, DC")}
        };
        
        return venues.ContainsKey(teamAbbrev) ? venues[teamAbbrev] : ("TBD", "TBD");
    }
    
    string CleanScore(string score)
    {
        if (string.IsNullOrEmpty(score)) return score;
        
        if (score.Contains(" "))
        {
            return score.Split(' ')[0];
        }
        return score;
    }
}

<style>
    .players-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 30px 20px;
    }

    .page-header {
        background: linear-gradient(135deg, #1a1a1a 0%, #2c2c2c 100%);
        border-radius: 20px;
        padding: 40px;
        margin-bottom: 30px;
        color: white;
        position: relative;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

        .page-header::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 8px;
            background: linear-gradient(90deg, #ff6b35 0%, #ff8c5a 100%);
        }

    .page-title {
        font-size: 2.5em;
        font-weight: 800;
        margin-bottom: 10px;
        letter-spacing: -0.02em;
    }

    .players-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .player-card {
        background: white;
        border-radius: 15px;
        overflow: hidden;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        border: 1px solid #e0e0e0;
        transition: transform 0.3s ease;
        text-decoration: none;
        color: inherit;
        display: block;
    }

        .player-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.1);
        }

    .player-card-header {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        padding: 20px;
        text-align: center;
        border-bottom: 2px solid #ff6b35;
    }

    .player-card-image {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        object-fit: cover;
        border: 3px solid white;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }

    .player-card-body {
        padding: 20px;
        text-align: center;
    }

    .player-card-name {
        font-size: 1.2em;
        font-weight: 700;
        color: #333;
        margin-bottom: 8px;
    }

    .player-card-meta {
        display: flex;
        justify-content: center;
        gap: 15px;
        color: #666;
        font-size: 0.9em;
    }

    .player-card-team {
        background: #f0f0f0;
        padding: 3px 8px;
        border-radius: 15px;
        font-weight: 600;
    }

    .player-profile {
        background: white;
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        border: 1px solid #e0e0e0;
    }

    .profile-header {
        display: flex;
        gap: 40px;
        align-items: center;
        margin-bottom: 40px;
        flex-wrap: wrap;
        justify-content: space-between;
    }

    .profile-header-left {
        display: flex;
        gap: 40px;
        align-items: center;
        flex-wrap: wrap;
    }

    .profile-image {
        width: 200px;
        height: 200px;
        border-radius: 50%;
        object-fit: cover;
        border: 4px solid #ff6b35;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }

    .profile-title h1 {
        font-size: 3em;
        font-weight: 800;
        color: #1a1a1a;
        margin-bottom: 10px;
    }

    .profile-title .player-number {
        background: #ff6b35;
        color: white;
        padding: 5px 15px;
        border-radius: 25px;
        font-size: 1.2em;
        font-weight: 600;
        display: inline-block;
    }

    .team-info {
        text-align: right;
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 15px;
    }

    .team-logo-link {
        display: inline-block;
        transition: transform 0.3s ease;
    }

        .team-logo-link:hover {
            transform: scale(1.1);
        }

    .team-logo {
        width: 150px;
        height: 150px;
        object-fit: contain;
        background: white;
        border-radius: 50%;
        padding: 15px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        border: 3px solid #ff6b35;
    }

    .team-name-link {
        color: #ff6b35;
        text-decoration: none;
        font-weight: 700;
        font-size: 1.5em;
        transition: color 0.3s ease;
    }

        .team-name-link:hover {
            color: #ff5420;
            text-decoration: underline;
        }

    .info-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .info-card {
        background: #f8f9fa;
        border-radius: 15px;
        padding: 20px;
        border: 1px solid #e0e0e0;
    }

        .info-card h3 {
            color: #ff6b35;
            margin-bottom: 15px;
            font-size: 1.2em;
            border-bottom: 1px solid #e0e0e0;
            padding-bottom: 10px;
        }

    .info-row {
        display: flex;
        justify-content: space-between;
        padding: 8px 0;
        border-bottom: 1px dashed #e0e0e0;
    }

        .info-row:last-child {
            border-bottom: none;
        }

    .info-label {
        color: #666;
        font-weight: 500;
    }

    .info-value {
        color: #333;
        font-weight: 700;
    }

    .stats-section {
        margin: 40px 0;
        background: white;
        border-radius: 20px;
        padding: 30px;
        border: 1px solid #e0e0e0;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
        gap: 20px;
        margin-top: 20px;
    }

    .stat-item {
        text-align: center;
        padding: 15px;
        background: #f8f9fa;
        border-radius: 12px;
        border: 1px solid #e0e0e0;
    }

    .stat-label {
        color: #666;
        font-size: 0.9em;
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .stat-value {
        font-size: 2em;
        font-weight: 700;
        color: #1a1a1a;
    }

    .stat-detail {
        color: #888;
        font-size: 0.85em;
        margin-top: 5px;
    }

    .totals-section {
        margin: 40px 0;
        background: white;
        border-radius: 20px;
        padding: 30px;
        border: 1px solid #e0e0e0;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    }

    .totals-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin-top: 20px;
    }

    .total-item {
        text-align: center;
        padding: 20px;
        background: linear-gradient(135deg, #ff6b35 0%, #ff8c5a 100%);
        border-radius: 12px;
        color: white;
    }

    .total-label {
        font-size: 0.9em;
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        opacity: 0.9;
    }

    .total-value {
        font-size: 2.2em;
        font-weight: 800;
    }

    .games-log-section {
        margin: 40px 0;
        background: white;
        border-radius: 20px;
        padding: 30px;
        border: 1px solid #e0e0e0;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    }

    .games-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 15px;
        margin-top: 20px;
    }

    .game-card {
        background: white;
        border-radius: 15px;
        overflow: hidden;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        border: 1px solid #e0e0e0;
        transition: transform 0.3s ease;
        padding: 20px;
    }

        .game-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.1);
        }

    .game-header {
        display: flex;
        align-items: center;
        margin-bottom: 15px;
        padding-bottom: 15px;
        border-bottom: 2px solid #f0f0f0;
    }

    .game-date {
        min-width: 120px;
        text-align: center;
        padding-right: 20px;
        border-right: 2px solid #f0f0f0;
    }

        .game-date .day {
            font-size: 2em;
            font-weight: 700;
            color: #333;
            line-height: 1;
        }

        .game-date .month {
            font-size: 1em;
            color: #ff6b35;
            font-weight: 600;
            text-transform: uppercase;
        }

        .game-date .time {
            font-size: 0.9em;
            color: #999;
            margin-top: 5px;
        }

    .game-teams {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 20px;
    }

    .team-display {
        display: flex;
        align-items: center;
        gap: 15px;
        min-width: 200px;
        text-decoration: none;
        color: inherit;
        transition: all 0.2s ease;
    }

        .team-display:hover {
            transform: scale(1.02);
        }

            .team-display:hover .team-name-small {
                color: #ff6b35;
            }

            .team-display:hover .team-logo-small {
                transform: scale(1.1);
            }

        .team-display.away {
            justify-content: flex-end;
        }

    .team-logo-small {
        width: 40px;
        height: 40px;
        object-fit: contain;
        transition: transform 0.2s ease;
    }

    .team-info {
        text-align: left;
    }

    .team-display.away .team-info {
        text-align: right;
    }

    .team-name-small {
        font-size: 1.1em;
        font-weight: 600;
        color: #333;
        transition: color 0.2s ease;
    }

    .team-full-name {
        font-size: 0.9em;
        color: #666;
    }

    .game-score-link {
        text-decoration: none;
        display: inline-block;
        transition: transform 0.2s ease;
        cursor: pointer;
    }

        .game-score-link:hover {
            transform: scale(1.05);
        }

    .game-score {
        font-size: 1.8em;
        font-weight: 700;
        padding: 0 20px;
        min-width: 100px;
        text-align: center;
        color: #333;
    }

    .game-status {
        min-width: 200px;
        text-align: center;
        padding-left: 20px;
        border-left: 2px solid #f0f0f0;
    }

    .status-badge-final {
        background: #27ae60;
        color: white;
        padding: 6px 15px;
        border-radius: 25px;
        font-size: 0.9em;
        font-weight: 600;
        display: inline-block;
        margin-bottom: 8px;
    }

    .venue-info {
        font-size: 0.85em;
        color: #999;
        line-height: 1.4;
    }

        .venue-info i {
            color: #ff6b35;
            width: 16px;
            margin-right: 4px;
        }

        .venue-info .venue-name {
            font-weight: 600;
            color: #666;
        }

        .venue-info .venue-city {
            font-size: 0.95em;
            color: #999;
            margin-top: 2px;
        }

    .player-stats-row {
        display: flex;
        align-items: center;
        gap: 20px;
        padding: 10px 0;
        background: #f8f9fa;
        border-radius: 10px;
        border: 1px solid #e0e0e0;
        flex-wrap: wrap;
        justify-content: center;
    }

    .stat-item-inline {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 0 15px;
        border-right: 1px solid #e0e0e0;
    }

        .stat-item-inline:last-child {
            border-right: none;
        }

        .stat-item-inline .stat-label {
            font-size: 0.9em;
            color: #999;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .stat-item-inline .stat-value {
            font-size: 1.2em;
            font-weight: 700;
            color: #ff6b35;
        }

        .stat-item-inline .stat-detail {
            font-size: 0.9em;
            color: #666;
            margin-left: 5px;
        }

    .positive {
        color: #28a745 !important;
    }

    .negative {
        color: #dc3545 !important;
    }

    .standings-footer {
        margin-top: 40px;
        padding: 20px;
        background: #f8f9fa;
        border-radius: 15px;
        border: 1px solid #e0e0e0;
    }

    .footer-note {
        margin-bottom: 25px;
        padding-bottom: 20px;
        border-bottom: 1px solid #ddd;
    }

        .footer-note p {
            color: #666;
            font-size: 0.95em;
            margin: 8px 0;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .footer-note i {
            color: #ff6b35;
            width: 20px;
            font-size: 1.1em;
        }

    .glossary {
        margin-top: 20px;
    }

        .glossary h3 {
            color: #333;
            font-size: 1.2em;
            font-weight: 700;
            margin-bottom: 20px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

    .glossary-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 15px;
    }

    .glossary-item {
        color: #666;
        font-size: 0.9em;
        line-height: 1.5;
    }

        .glossary-item .abbr {
            font-weight: 700;
            color: #ff6b35;
            margin-right: 8px;
            display: inline-block;
            min-width: 60px;
        }

    .back-button {
        display: inline-block;
        background: #ff6b35;
        color: white;
        padding: 12px 30px;
        border-radius: 30px;
        text-decoration: none;
        font-weight: 600;
        margin-top: 40px;
        transition: all 0.3s ease;
        border: 2px solid transparent;
    }

        .back-button:hover {
            background: white;
            color: #ff6b35;
            border-color: #ff6b35;
            transform: translateX(-5px);
        }

        .back-button i {
            margin-right: 8px;
        }

    .text-center {
        text-align: center;
    }

    .game-result-center {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 5px;
        min-width: 150px;
    }

    .result-badge {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.8em;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }

        .result-badge.victory {
            background: linear-gradient(135deg, #27ae60, #2ecc71);
            color: white;
        }

            .result-badge.victory i {
                color: #f1c40f;
                margin-right: 5px;
            }

        .result-badge.defeat {
            background: linear-gradient(135deg, #e74c3c, #c0392b);
            color: white;
        }

            .result-badge.defeat i {
                color: #f39c12;
                margin-right: 5px;
            }

    @@media (max-width: 768px) {
        .glossary-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 480px) {
        .glossary-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 992px) {
        .game-header {
            flex-direction: column;
            text-align: center;
        }

        .game-date {
            border-right: none;
            border-bottom: 2px solid #f0f0f0;
            padding-right: 0;
            padding-bottom: 15px;
            margin-bottom: 15px;
            width: 100%;
        }

        .game-teams {
            flex-direction: column;
            gap: 15px;
            width: 100%;
            padding: 0;
        }

        .team-display {
            width: 100%;
            justify-content: center;
        }

            .team-display.away {
                justify-content: center;
            }

        .game-status {
            border-left: none;
            border-top: 2px solid #f0f0f0;
            padding-left: 0;
            padding-top: 15px;
            margin-top: 15px;
            width: 100%;
        }

        .player-stats-row {
            flex-direction: column;
            align-items: flex-start;
        }

        .stat-item-inline {
            border-right: none;
            border-bottom: 1px solid #e0e0e0;
            padding: 10px 15px;
            width: 100%;
        }

            .stat-item-inline:last-child {
                border-bottom: none;
            }
    }

    @@media (max-width: 768px) {
        .profile-header {
            flex-direction: column;
            text-align: center;
        }

        .profile-header-left {
            flex-direction: column;
            text-align: center;
            gap: 20px;
        }

        .team-info {
            text-align: center;
            align-items: center;
        }

        .profile-image {
            width: 150px;
            height: 150px;
        }

        .team-logo {
            width: 120px;
            height: 120px;
        }

        .profile-title h1 {
            font-size: 2.2em;
        }

        .page-title {
            font-size: 2em;
        }

        .players-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="players-container">
    <div class="page-header">
        <h1 class="page-title">
            <i class="fas fa-user" style="margin-right: 15px; color: #ff6b35;"></i>
            Профиль игрока
        </h1>
    </div>

    <div class="player-profile">
        <div class="profile-header">
            <div class="profile-header-left">
                <img src="@Model.HeadshotUrl" class="profile-image" alt="@Model.DisplayName"
                     onerror="this.onerror=null;">
                <div class="profile-title">
                    <h1>@Model.DisplayName</h1>
                    @if (!string.IsNullOrEmpty(Model.Jersey))
                    {
                        <span class="player-number">#@Model.Jersey</span>
                    }
                </div>
            </div>
            @if (!string.IsNullOrEmpty(Model.TeamAbbrev))
            {
                string teamAbbrev = GetTeamAbbrev(Model.TeamAbbrev);
                <div class="team-info">
                    <a href="@Url.Action("TeamDetails", "Team", new { abbrev = teamAbbrev })" class="team-logo-link">
                        <img src="@GetTeamLogoUrl(teamAbbrev)"
                             class="team-logo"
