<script>
    function showTeamPlayers(team) {
        document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
        document.querySelectorAll('.players-table').forEach(table => table.style.display = 'none');

        if (team === 'away') {
            document.querySelectorAll('.tab-btn')[0].classList.add('active');
            document.getElementById('away-players').style.display = 'block';
        } else {
            document.querySelectorAll('.tab-btn')[1].classList.add('active');
            document.getElementById('home-players').style.display = 'block';
        }
    }

    document.addEventListener('DOMContentLoaded', function() {
        showTeamPlayers('away');
    });
</script>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const images = document.querySelectorAll('.player-headshot');
        
        images.forEach((img, index) => {
            const originalWidth = img.offsetWidth;
            const originalHeight = img.offsetHeight;
            
            if (img.complete) {
                checkImage(img, index, originalWidth, originalHeight);
            } else {
                img.onload = function() {
                    checkImage(this, index, this.offsetWidth, this.offsetHeight);
                };
            }
            
            img.onerror = function() {
                replaceWithBlack(this, originalWidth, originalHeight);
            };
        });
        
        function checkImage(img, index, width, height) {
            try {
                const canvas = document.createElement('canvas');
                canvas.width = img.width || 30;
                canvas.height = img.height || 30;
                const ctx = canvas.getContext('2d', { willReadFrequently: true });
                
                try {
                    ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
                    
                    const points = [
                        [Math.floor(canvas.width/2), Math.floor(canvas.height/2)],
                        [5, 5],
                        [canvas.width-5, 5],
                        [5, canvas.height-5],
                        [canvas.width-5, canvas.height-5]
                    ];
                    
                    let transparentPixels = 0;
                    
                    for (let [x, y] of points) {
                        const pixel = ctx.getImageData(x, y, 1, 1).data;
                        if (pixel[3] === 0) {
                            transparentPixels++;
                        }
                    }
                    
                    if (transparentPixels === points.length) {
                        replaceWithBlack(img, width, height);
                    }
                    
                } catch (e) {
                    console.log(e);
                }
                
            } catch (e) {
                console.log(e);
            }
        }
        
        function replaceWithBlack(img, width, height) {
            const parent = img.parentNode;
            if (parent) {
                const placeholder = document.createElement('div');
                placeholder.className = img.className;
                placeholder.style.width = width + 'px';
                placeholder.style.height = height + 'px';
                placeholder.style.backgroundColor = '#000000';
                placeholder.style.borderRadius = window.getComputedStyle(img).borderRadius;
                placeholder.style.margin = window.getComputedStyle(img).margin;
                parent.replaceChild(placeholder, img);
            }
        }
    });
</script>