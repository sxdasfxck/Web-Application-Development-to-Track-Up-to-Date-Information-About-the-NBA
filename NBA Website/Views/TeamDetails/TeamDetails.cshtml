@model NBA_Website.Models.TeamDetailViewModel

@{
    ViewData["Title"] = Model.DisplayName;
}

<style>
    .team-detail-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 30px 20px;
    }

    .team-header {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        border-radius: 20px;
        padding: 40px;
        margin-bottom: 30px;
        border: 1px solid #e0e0e0;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }

    .team-header-content {
        display: flex;
        align-items: center;
        gap: 50px;
        flex-wrap: wrap;
    }

    .team-logo {
        width: 150px;
        height: 150px;
        object-fit: contain;
        background: white;
        border-radius: 50%;
        padding: 15px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }

    .team-title {
        flex: 1;
    }

    .team-name {
        font-size: 3em;
        font-weight: 800;
        color: #1a1a1a;
        margin-bottom: 10px;
    }

    .team-location {
        font-size: 1.2em;
        color: #666;
        margin-bottom: 15px;
    }

        .team-location i {
            color: #ff6b35;
            margin-right: 8px;
        }

    .team-badge {
        background: #ff6b35;
        color: white;
        padding: 6px 15px;
        border-radius: 20px;
        font-size: 0.9em;
        font-weight: 600;
        display: inline-block;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: white;
        border-radius: 15px;
        padding: 25px 20px;
        text-align: center;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        border: 1px solid #e0e0e0;
        transition: transform 0.3s ease;
    }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.1);
        }

    .stat-label {
        font-size: 0.9em;
        color: #999;
        text-transform: uppercase;
        margin-bottom: 10px;
        letter-spacing: 1px;
    }

    .stat-value {
        font-size: 2.2em;
        font-weight: 700;
        color: #333;
    }

        .stat-value.positive {
            color: #27ae60;
        }

        .stat-value.negative {
            color: #e74c3c;
        }

    .links-section {
        margin-top: 40px;
    }

    .links-title {
        font-size: 1.3em;
        font-weight: 700;
        color: #333;
        margin-bottom: 20px;
        padding-bottom: 10px;
        border-bottom: 2px solid #ff6b35;
    }

    .links-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 20px;
    }

    .team-link {
        background: #f0f0f0;
        color: #666;
        padding: 10px 20px;
        border-radius: 25px;
        font-size: 0.95em;
        font-weight: 600;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        border: none;
        cursor: pointer;
        font-family: 'Helvetica', Arial, sans-serif;
        text-decoration: none;
        flex: 1 1 auto;
        min-width: 120px;
        outline: none;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        line-height: 1;
    }

        .team-link:hover {
            background: #ff6b35;
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(255,107,53,0.3);
        }

        .team-link:active {
            transform: translateY(0);
            box-shadow: 0 2px 8px rgba(255,107,53,0.2);
        }

        .team-link:focus {
            outline: none;
        }

        .team-link i {
            font-size: 1.1em;
            transition: transform 0.3s ease;
        }

        .team-link:hover i {
            transform: scale(1.1);
        }

    button.team-link {
        -webkit-appearance: none;
        -moz-appearance: none;
        appearance: none;
        background: #f0f0f0;
    }

        button.team-link:hover {
            background: #ff6b35;
        }

    .back-button {
        display: inline-block;
        background: #ff6b35;
        color: white;
        padding: 12px 30px;
        border-radius: 30px;
        text-decoration: none;
        font-weight: 600;
        margin-top: 40px;
        transition: all 0.3s ease;
        border: 2px solid transparent;
    }

        .back-button:hover {
            background: white;
            color: #ff6b35;
            border-color: #ff6b35;
            transform: translateX(-5px);
        }

    .text-center {
        text-align: center;
    }

    @@media (max-width: 768px) {
        .team-header-content {
            flex-direction: column;
            text-align: center;
        }

        .team-name {
            font-size: 2.2em;
        }

        .stats-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 480px) {
        .stats-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="team-detail-container">
    <div class="team-header">
        <div class="team-header-content">
            @if (!string.IsNullOrEmpty(Model.LogoUrl))
            {
                <img src="@Model.LogoUrl" class="team-logo" alt="@Model.DisplayName">
            }
            else
            {
                <div class="team-logo" style="background: linear-gradient(135deg, #f8f9fa, #e9ecef); display: flex; align-items: center; justify-content: center;">
                    <span style="color: #666; font-size: 2.5em; font-weight: 800;">@Model.Abbreviation</span>
                </div>
            }
            <div class="team-title">
                <h1 class="team-name">@Model.DisplayName</h1>
                <p class="team-location">
                    <i class="fas fa-map-marker-alt"></i> @Model.Location
                </p>
                <span class="team-badge">@Model.Abbreviation</span>
            </div>
        </div>
    </div>

    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-label">Победы</div>
            <div class="stat-value">@Model.Wins</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Поражения</div>
            <div class="stat-value">@Model.Losses</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">% побед</div>
            <div class="stat-value">@Model.WinPct.ToString("F3")</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Место</div>
            <div class="stat-value">#@Model.PlayoffSeed</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Очки за игру</div>
            <div class="stat-value">@Model.PPG.ToString("F1")</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Пропущено</div>
            <div class="stat-value">@Model.OppPPG.ToString("F1")</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Разница</div>
            <div class="stat-value @(Model.Diff >= 0 ? "positive" : "negative")">
                @(Model.Diff >= 0 ? "+" : "")@Model.Diff.ToString("F1")
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Серия</div>
            <div class="stat-value">@Model.Streak</div>
        </div>
    </div>

    @if (Model.Links.Any())
    {
        <div class="links-section">
            <h3 class="links-title">
                <i class="fas fa-link"></i> Разделы команды
            </h3>
            <div class="links-grid">
                @foreach (var link in Model.Links)
                {
                    @if (link.Rel.Contains("roster"))
                    {
                        <a href="@Url.Action("Roster", "Roster", new { abbrev = Model.Abbreviation })" class="team-link">
                            <i class="fas fa-users"></i> Состав
                        </a>
                    }
                    else if (link.Rel.Contains("depthchart"))
                    {
                        <a href="@Url.Action("DepthChart", "DepthChart", new { abbrev = Model.Abbreviation })" class="team-link">
                            <i class="fas fa-layer-group"></i> Глубина состава
                        </a>
                    }
                    else if (link.Rel.Contains("injuries"))
                    {
                        <a href="@Url.Action("Injuries", "Injuries", new { abbrev = Model.Abbreviation })" class="team-link">
                            <i class="fas fa-ambulance"></i> Травмы
                        </a>
                    }
                    else if (link.Rel.Contains("schedule"))
                    {
                        <a href="@Url.Action("Schedule", "Schedule", new { abbrev = Model.Abbreviation })" class="team-link">
                            <i class="fas fa-calendar-alt"></i> Расписание
                        </a>
                    }
                    else
                    {
                        <button class="link-button" onclick="alert('Страница будет доступна позже')">
                            <i class="fas fa-external-link-alt"></i> @link.Text
                        </button>
                    }
                }
            </div>
        </div>
    }

    <div class="text-center">
        <a href="javascript:history.back()" class="back-button">
            <i class="fas fa-arrow-left"></i> Назад
        </a>
    </div>
</div>